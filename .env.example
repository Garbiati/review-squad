# === Notification Webhooks ===
# Uncomment and fill in the webhook URLs for the providers you want to use.
# These URLs are secrets — NEVER commit .env to git.

# Slack: https://api.slack.com/messaging/webhooks
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Microsoft Teams: https://learn.microsoft.com/en-us/microsoftteams/platform/webhooks-and-connectors/how-to/add-incoming-webhook
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# Discord: https://discord.com/developers/docs/resources/webhook
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/.../...

# === User Resolution (auto-resolve GitHub users to notification platform users) ===
# Slack Bot Token with users:read.email scope — resolves GitHub users to Slack by email.
# Can be the same token as SLACK_BOT_TOKEN if you run the Slack bot.
# SLACK_RESOLVE_TOKEN=xoxb-...

# === Usage Estimation ===
# "true" = include usage statistics in notifications and console output
# REVIEW_VERBOSE=true

# === Slack Bot (Socket Mode) ===
# See integrations/slack-bot/README.md for setup instructions.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
