{
  "github": {
    "review_account": "john-reviewer",
    "default_org": "acme-health"
  },
  "review": {
    "language": "en",
    "severity_levels": {
      "critical": "🔴 CRITICAL",
      "major": "🟠 MAJOR",
      "minor": "🟡 MINOR",
      "suggestion": "🔵 SUGGESTION",
      "positive": "✅ POSITIVE"
    },
    "default_event": "COMMENT",
    "default_tier": "focused",
    "max_files_inline_review": 30,
    "ignore_patterns": [
      "*.designer.cs",
      "*.generated.cs",
      "*.g.cs",
      "package-lock.json",
      "yarn.lock",
      "pnpm-lock.yaml",
      "*.min.js",
      "*.min.css",
      "Migrations/*.cs",
      "*.pb.go",
      "go.sum"
    ],
    "tiers": {
      "quick": {
        "agents": ["code"],
        "read_local_context": false,
        "severity_filter": ["critical", "major"]
      },
      "focused": {
        "agents": ["code", "security", "testing", "qa"],
        "read_local_context": true,
        "max_context_files": 15,
        "severity_filter": null
      },
      "full": {
        "agents": ["code", "security", "testing", "qa", "architecture", "performance"],
        "read_local_context": true,
        "max_context_files": 30,
        "severity_filter": null
      }
    }
  },
  "agents": {
    "full_review": ["code", "security", "testing", "qa", "architecture", "performance"],
    "available": {
      "code": { "enabled": true },
      "security": { "enabled": true },
      "testing": { "enabled": true },
      "qa": { "enabled": true },
      "architecture": { "enabled": true },
      "performance": { "enabled": true }
    }
  },
  "repo_profiles": {
    "acme-health/backend-api": "dotnet-core-api",
    "acme-health/auth-service": "dotnet-auth",
    "acme-health/shared-lib": "dotnet-shared-lib",
    "acme-health/worker-notifications": "dotnet-core-service",
    "acme-health/worker-matching": "dotnet-core-service",
    "acme-health/legacy-api": "dotnet-legacy-api",
    "acme-health/web-app": "typescript-react",
    "acme-health/mobile-app": "typescript-react-native",
    "acme-health/design-system": "typescript-react",
    "acme-health/socket-service": "typescript-node",
    "acme-health/data-pipeline": "python",
    "acme-health/ml-models": "python",
    "acme-health/admin-panel": "vue",
    "acme-health/db-scripts": "sql",
    "acme-health/gateway": "go",
    "acme-health/crypto-service": "rust"
  }
}
