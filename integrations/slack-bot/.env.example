# === Slack App Tokens ===
# Create a Slack App at https://api.slack.com/apps
# See README.md for step-by-step setup instructions.

# Bot User OAuth Token (xoxb-...)
# Found at: OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-token

# App-Level Token (xapp-...)
# Found at: Basic Information → App-Level Tokens (connections:write scope)
SLACK_APP_TOKEN=xapp-your-token

# === Review Squad ===
# Absolute path to the review-squad project directory.
# The bot uses this as cwd when invoking Claude Code SDK.
REVIEW_SQUAD_DIR=/home/you/projects/review-squad

# === Optional ===
# Comma-separated Slack user IDs allowed to trigger reviews.
# Leave empty to allow all users in the workspace.
# ALLOWED_SLACK_USERS=U01ABC,U02DEF
